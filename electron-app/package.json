{
  "name": "autoto",
  "version": "1.0.0",
  "description": "AutoTo - 一鍵安裝的 AI 智能助理",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win",
    "dev": "electron . --dev"
  },
  "build": {
    "appId": "com.autoto.app",
    "productName": "AutoTo",
    "directories": {
      "output": "../dist"
    },
    "files": [
      "**/*",
      "!node_modules/.cache"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "target": ["dmg", "zip"]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": ["nsis"],
      "nsis": {
        "oneClick": true,
        "allowToChangeInstallationDirectory": false,
        "createDesktopShortcut": true,
        "runAfterFinish": true
      }
    }
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "express": "^4.18.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
